generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  vocabularies  Vocabulary[]
  readingLogs   ReadingLog[]
  createdAt     DateTime      @default(now())
}

model News {
  id           String        @id @default(cuid())
  title        String
  summary      String
  content      String?
  source       String
  sourceUrl    String
  category     String
  level        String        @default("Intermediate")
  imageUrl     String?
  publishedAt  DateTime
  createdAt    DateTime      @default(now())
  annotations  String?
  vocabularies Vocabulary[]

  // 新增：段落翻译和长难句分析
  paragraphTranslations String?  // JSON: [{paragraph, translation}]
  complexSentences      String?  // JSON: [{sentence, structure, explanation}]
  wordCount             Int?     // 文章字数
  readingTime           Int?     // 预估阅读时长（分钟）
}

model Vocabulary {
  id           String      @id @default(cuid())
  userId       String
  newsId       String
  word         String
  ipa          String?
  meaning      String
  level        String
  context      String
  collocations String?

  // 新增：词汇扩展信息
  etymology    String?     // 词根词缀
  synonyms     String?     // 同义词（JSON数组）
  antonyms     String?     // 反义词（JSON数组）
  derivatives  String?     // 派生词（JSON数组）
  wordFamily   String?     // 词族（JSON数组）

  nextReview   DateTime    @default(now())
  interval     Int         @default(0)
  easeFactor   Float       @default(2.5)
  repetitions  Int         @default(0)
  lastQuality  Int?        // 最近一次评分
  createdAt    DateTime    @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  news         News        @relation(fields: [newsId], references: [id], onDelete: Cascade)
  reviewLogs   ReviewLog[]

  @@unique([userId, word, newsId])
}

model ReviewLog {
  id           String     @id @default(cuid())
  vocabularyId String
  quality      Int
  reviewType   String     @default("recognition") // recognition | spelling | context
  reviewedAt   DateTime   @default(now())
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
}

model ReadingLog {
  id             String   @id @default(cuid())
  userId         String
  newsId         String
  readAt         DateTime @default(now())
  duration       Int?
  progress       Float    @default(0)    // 阅读进度 0-1
  completed      Boolean  @default(false) // 是否读完
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId, readAt])
}
